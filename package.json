{
  "name": "markui",
  "version": "0.1.0",
  "description": "Lightweight visual feedback overlay for React apps — left-click any element, mark it red, add a comment, and copy all requests for your AI coding agent.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "markui-server": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "keywords": [
    "react",
    "annotation",
    "overlay",
    "visual-feedback",
    "ai-agent",
    "ui-feedback"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  }
}
